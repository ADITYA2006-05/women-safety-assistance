PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# PostgreSQL database URL (e.g. Supabase, Neon)
DATABASE_URL=postgresql://username:password@localhost:5432/women_safety
# Or alternatively
POSTGRES_URI=postgresql://username:password@localhost:5432/women_safety

# Set to true if SSL connection is required by your database host (e.g. Neon, Supabase)
DB_SSL=true
